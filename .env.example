# Copy this file to .env and fill in values as you provision each service.
# Every integration in lib/commerce/ falls back to a local dev implementation
# when its keys are absent, so the app runs end-to-end with this file empty.
# See COMMERCE_SETUP.md for what each var unlocks.

# 5000 is claimed by macOS's AirPlay Receiver on many Macs; 5050 avoids the conflict.
PORT=5050

# --- Supabase (products/orders/customers/campaigns) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk (auth, B2B role tiers: customer/wholesaler/admin) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# --- Stripe (checkout + webhooks) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@example.com

# --- PostHog (event analytics) ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# --- Upstash Redis (cart cache) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Pinecone (semantic product search) ---
PINECONE_API_KEY=
PINECONE_INDEX=comley-products

# --- OpenAI (embeddings for Pinecone; the spec's Pinecone step needs a vector
# source, and OpenAI's text-embedding-3-small is the standard pairing) ---
OPENAI_API_KEY=

# --- Anthropic (page editor "Paste in" block classification, lib/ai.js) ---
# Optional: without this, paste-in still segments deterministically, but
# any block the heuristics can't confidently label stays "unknown" instead
# of getting an LLM-assisted guess.
ANTHROPIC_API_KEY=

# --- Frontend-exposed public keys (Vite only inlines VITE_-prefixed vars) ---
VITE_CLERK_PUBLISHABLE_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Multi-tenant / Nexus platform ---
# Comma-separated emails with platform super-admin rights (org management,
# Nexus's own site pages at /super-admin). Independent of org membership.
ADMIN_EMAILS=
# Optional: pin an org id to serve when a request's Host doesn't match any
# org's `domain` column. Leave unset -- the default (and normal) behavior
# is that an unmatched host (including the bare nexus.comleycreative.com
# domain) serves Nexus's own site, since that's the front door people land
# on before signing up. A client's own content only takes over once their
# `domain` column is set on their org row.
DEFAULT_PUBLIC_ORG_ID=

# --- Social (Sprout-style publishing + analytics) ---
# The whole surface runs in a "sandbox" that fakes every platform so the flow
# is testable with no real credentials. Force it on in dev with SOCIAL_SANDBOX=1;
# in prod, each platform automatically uses its real adapter once its
# credentials below are present, and sandboxes otherwise (per-platform).
SOCIAL_SANDBOX=
# Absolute base URL for OAuth redirect URIs + QStash callbacks (e.g.
# https://app.example.com). Falls back to the request host when unset.
PUBLIC_BASE_URL=
# Shared secret guarding the /api/social/cron/* endpoints (publish-due,
# refresh-tokens, poll-metrics) so QStash / Vercel Cron can call them. When
# unset, cron endpoints are open in dev and closed in prod.
SOCIAL_CRON_SECRET=
# QStash (Upstash) for timed publishing. With both set, scheduled posts are
# delivered by QStash; without them, an in-process timer fires near-term posts
# and the publish-due cron sweep is the durable backstop.
QSTASH_TOKEN=
# Per-platform app credentials. Present = that platform goes live; absent =
# it stays in sandbox. Instagram + Facebook share one Meta app.
META_APP_ID=
META_APP_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# --- Newsletter / email builder (Sailthru-style block editor + campaigns) ---
# A standard CMS feature (shown as "Newsletter" in nav) available to every
# workspace -- no feature flag, not tied to Commerce. Real sending only happens
# when Resend is configured below; otherwise sends sandbox (logged, not
# delivered). EMAIL_SANDBOX=1 forces that sandbox even when Resend IS set --
# handy for local testing of the full build -> audience -> send -> stats flow.
EMAIL_SANDBOX=
# Sending uses the existing Resend integration (RESEND_API_KEY + RESEND_FROM,
# already above for form notifications). Open/click tracking needs an absolute
# base URL — reuses PUBLIC_BASE_URL (set for social). AI generation reuses
# ANTHROPIC_API_KEY (already above). Scheduled sends run via the send-due cron.
